{
  "knowledge": {
    "KN_001": {
      "knowledge_id": "KN_001",
      "document_type": "법률",
      "title": "적합성원칙",
      "content": "금융상품판매업자등은 일반금융소비자의 정보를 파악하고, 부적합한 금융상품 계약 체결을 권유해서는 아니 된다."
    },
    "KN_002": {
      "knowledge_id": "KN_002",
      "document_type": "법률",
      "title": "적정성원칙",
      "content": "판매업자등은 권유 없이 계약하려는 경우에도 상품이 일반금융소비자에게 적정한지 판단하고 부적정 시 알려야 한다."
    },
    "KN_003": {
      "knowledge_id": "KN_003",
      "document_type": "법률",
      "title": "설명의무",
      "content": "계약 체결 권유 시 및 소비자 요청 시 금융상품의 중요한 사항을 이해할 수 있도록 설명하여야 한다."
    },
    "KN_004": {
      "knowledge_id": "KN_004",
      "document_type": "법률",
      "title": "설명서 제공·이해 확인",
      "content": "설명서를 제공하고, 이해하였음을 서명·기명날인·녹취 등으로 확인받아야 한다."
    },
    "KN_007": {
      "knowledge_id": "KN_007",
      "document_type": "법률",
      "title": "부당권유행위 금지",
      "content": "금융상품 권유 시 소비자가 오인할 우려가 있는 행위(단정적 판단 제공, 적합성원칙 회피 목적의 확인서 징구, 요청하지 않은 다른 상품 권유, 객관적 근거 없는 비교 등)를 하여서는 아니 된다."
    },
    "KN_009": {
      "knowledge_id": "KN_009",
      "document_type": "법률",
      "title": "자료의 기록·유지 및 열람",
      "content": "판매업자등은 판매 관련 자료를 기록·유지하여야 하며, 소비자의 열람 요구 시 정한 기한 내 열람하게 하여야 한다."
    },
    "KN_010": {
      "knowledge_id": "KN_010",
      "document_type": "법률",
      "title": "손해배상책임(설명의무 위반 입증책임 전환)",
      "content": "설명의무 위반으로 손해 발생 시 배상 책임을 지며, 고의·과실 없음을 판매업자등이 입증하여야 한다."
    },
    "KN_011": {
      "knowledge_id": "KN_011",
      "document_type": "법률",
      "title": "청약의 철회",
      "content": "일반금융소비자는 투자성 상품 계약서류 제공일 또는 계약체결일로부터 7일(대출성 14일) 내 청약을 철회할 수 있으며, 판매업자등은 청약철회 접수일부터 3영업일 이내에 이미 받은 금전을 반환하여야 한다."
    },
    "KN_012": {
      "knowledge_id": "KN_012",
      "document_type": "법률",
      "title": "위법계약의 해지",
      "content": "판매규제 위반 계약에 대해 소비자는 위반사실을 안 날부터 1년과 계약서류를 받은 날부터 5년 중 먼저 도래하는 기간 내에 해지를 요구할 수 있으며, 판매업자는 요구받은 날부터 10일 이내에 수락 여부를 통지하여야 한다."
    },
    "KN_013": {
      "knowledge_id": "KN_013",
      "document_type": "내규",
      "title": "감점·비계량 평가 기준",
      "content": "상담 품질 감점 항목 및 비계량 평가 항목의 판정 기준을 정한다."
    },
    "KN_014": {
      "knowledge_id": "KN_014",
      "document_type": "내규",
      "title": "고령투자자 판매 절차",
      "content": "만65세 이상: 전담창구 상담, 투자권유 유의상품 권유 시 관리직 지점장 사전확인, 비상연락용 조력자 연락처 확인(본인·조력자 동의), 지정인 알림 서비스 안내(대상상품 건별), 초고령(만80세 이상)은 조력자 동석 안내."
    },
    "KN_015": {
      "knowledge_id": "KN_015",
      "document_type": "내규",
      "title": "대면녹취 기준",
      "content": "일반금융소비자 대상 녹취 의무: 고령·부적합(부적정) 투자자는 모든 금융투자상품, 비고령·적합 투자자는 3등급 이상 상품(사모 대상 제한), 고난도 상품은 모든 개인 일반금융소비자. 녹취 범위는 투자성향 상담부터 적합성·설명의무·계약사항(계좌명·계좌번호·상품명·가입금액)까지 포함."
    },
    "KN_016": {
      "knowledge_id": "KN_016",
      "document_type": "내규",
      "title": "적합성·적정성판단보고서",
      "content": "신규투자자·고령투자자 등 대상 파생결합상품 권유 시 적합성보고서를 출력·설명·교부(미출력 시 가입불가, 원본 교부·사본 보관). 부적정 상품 가입 시 적정성 판단 결과와 이유를 기재한 적정성판단보고서 교부."
    },
    "KN_017": {
      "knowledge_id": "KN_017",
      "document_type": "내규",
      "title": "숙려제도",
      "content": "고난도 금융투자상품 및 적정성원칙 대상상품 가입 시 2영업일 숙려기간 부여. 숙려기간 중 투자위험·원금손실가능성·최대손실가능금액·취소기간/방법을 2회 안내(LMS). 가입의사 확인기간 내 최종 의사 미확인 시 자동취소·투자금 반환."
    },
    "KN_018": {
      "knowledge_id": "KN_018",
      "document_type": "내규",
      "title": "위법계약해지권 의무기준",
      "content": "계속적 계약(투자일임·랩·신탁)으로 기간 종료 전 해지 시 불이익이 발생하는 계약이 대상. 해지요구 접수일 10일 이내 수락 여부 통지. 해지 시 수수료·위약금 등 비용 없이 장래효로 해지."
    },
    "KN_019": {
      "knowledge_id": "KN_019",
      "document_type": "내규",
      "title": "판매 관련 자료 보존·제공",
      "content": "계약서류·계약이행자료(투자자정보확인서, 적합성보고서, 고령투자자상담확인서 등)·광고자료·권리행사자료를 유형별 기간 보존(대부분 10년). 서면 요청 시 6영업일 이내 제공, 열람 요구 시 8일 이내 열람 제공."
    },
    "KN_020": {
      "knowledge_id": "KN_020",
      "document_type": "내규",
      "title": "청약철회권 의무기준",
      "content": "고난도 단위형펀드·고난도 투자일임/금전신탁 대상(파생결합증권 제외). 청약철회 신청은 계약서류 제공일 또는 계약체결일로부터 7일 이내, 회사는 철회 신청 접수일부터 3영업일 이내에 대금을 반환(철회 완료). 철회권 행사 방해는 불공정 영업행위에 해당."
    },
    "KN_021": {
      "knowledge_id": "KN_021",
      "document_type": "내규",
      "title": "판매후 확인콜(해피콜)",
      "content": "개인 신규 가입건 대상 상품별 기준(일반펀드 매수 1천만원 이상 최초가입일 등)으로 매매(계약)일부터 7영업일 이내 수행. 고령자·부적합 고객은 금액 기준 없이 전건. 점검 항목: 적합성, 상품특징·위험사항 설명 여부, 필수 교부서류 수령 여부. 미응답 시 재접촉 해피콜(3회 이상 시도)."
    },
    "KN_022": {
      "knowledge_id": "KN_022",
      "document_type": "가이드라인",
      "title": "고령투자자 보호 기준",
      "content": "만 65세 이상 고령투자자에 대한 강화된 판매 절차(전담창구, 조력자, 숙려제도 등)를 적용한다."
    }
  },
